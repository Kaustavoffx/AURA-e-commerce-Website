// ============================================================
//  Prisma Schema — E-Commerce Application
//  Maps 1:1 to the PostgreSQL DDL in src/db/schema.sql
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ───────────────────────────────────────────────────

enum UserRole {
  customer
  admin
  vendor

  @@map("user_role")
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded

  @@map("order_status")
}

// ── Users ───────────────────────────────────────────────────

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole @default(customer)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  orders Order[]

  @@index([email], map: "idx_users_email")
  @@map("users")
}

// ── Products ────────────────────────────────────────────────

model Product {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku        String   @unique @db.VarChar(100)
  name       String   @db.VarChar(255)
  price      Decimal  @db.Decimal(12, 2)
  stock      Int      @default(0)
  attributes Json     @default("{}") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  orderItems OrderItem[]

  @@index([name], map: "idx_products_name")
  @@map("products")
}

// ── Orders ──────────────────────────────────────────────────

model Order {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  totalPrice Decimal     @map("total_price") @db.Decimal(14, 2)
  status     OrderStatus @default(pending)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user  User        @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  items OrderItem[]

  @@index([userId], map: "idx_orders_user_id")
  @@index([status], map: "idx_orders_status")
  @@map("orders")
}

// ── Order Items (junction table) ────────────────────────────

model OrderItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  historicalPrice Decimal  @map("historical_price") @db.Decimal(12, 2)
  quantity        Int
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onUpdate: Cascade, onDelete: Restrict)

  @@unique([orderId, productId], map: "uq_order_items_order_product")
  @@index([orderId], map: "idx_order_items_order_id")
  @@index([productId], map: "idx_order_items_product_id")
  @@map("order_items")
}
